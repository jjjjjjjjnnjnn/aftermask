[application]

config/name="Aftermask"
config/description="Every life leaves a mask on the world."
config/version="0.1.0"
run/main_scene="res://scenes/ui/title_screen.tscn"
config/features=PackedStringArray("4.4")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://src/autoloads/event_bus.gd"
GameManager="*res://src/autoloads/game_manager.gd"
WorldManager="*res://src/autoloads/world_manager.gd"
SaveManager="*res://src/autoloads/save_manager.gd"
AudioManager="*res://src/autoloads/audio_manager.gd"
LegacySystem="*res://src/systems/legacy/legacy_system.gd"
MMLClient="*res://ai-runtime/mml_client.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/stretch/mode="canvas_items"

